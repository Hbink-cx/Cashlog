{
  "name": "finance-app",
  "type": "module",
  "version": "1.0.0",
  "description": "最棒的本地端免费开源记账软件！无限级分类 · OCR截图导入 · 旭日图桑基图 · 全平台可用 · 零数据上传",
  "author": "BinKai Hong",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder --win --x64 --dir",
    "build:android": "vite build && npx cap sync android && cd android && gradlew assembleRelease && cd ..",
    "preview": "vite preview",
    "preview:electron": "vite build && electron . --dev"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^8.4.0",
    "clsx": "^2.1.1",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.bink.finance-app",
    "productName": "个人理财助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/*.cjs",
      "public/icon.png",
      "public/donate.jpg"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "个人理财助手-${version}-portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Finance"
    }
  }
}
